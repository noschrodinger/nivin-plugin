{
  "name": "Nivin Plugin Repo",
  "version": "1.4",
  "plugins": [
    {
      "id": "vidlink",
      "name": "VidLink",
      "type": "embed",
      "api": "https://vidlink.pro",
      "routes": {
        "movie": "/movie/{tmdbId}",
        "tv": "/tv/{tmdbId}/{season}/{episode}"
      }
    },
    {
      "id": "flixhq",
      "name": "FlixHQ (Español)",
      "type": "embed",
      "api": "https://flixhq.to",
      "routes": {
        "movie": "/movie/{tmdbId}",
        "tv": "/tv/{tmdbId}/{season}/{episode}"
      },
      "headers": {
        "Referer": "https://flixhq.to",
        "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36"
      }
    },
    {
      "id": "sflix",
      "name": "SFlix",
