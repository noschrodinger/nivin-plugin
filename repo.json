{
  "name": "Nivin Plugin Repo",
  "version": "1.3",
  "plugins": [
    {
      "id": "vidlink",
      "name": "VidLink (embed)",
      "type": "embed",
      "api": "https://vidlink.pro",
      "routes": {
        "movie": "/movie/{tmdbId}",
        "tv": "/tv/{tmdbId}/{season}/{episode}"
